# 环境变量配置示例
# 复制此文件为 .env 并修改实际值

# MySQL 配置
MYSQL_ROOT_PASSWORD=your_secure_password_here

# RabbitMQ 配置
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=your_secure_password_here

# MinIO 配置
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your_secure_password_here

# 备份配置
BACKUP_DIR=./backups
RETENTION_DAYS=7
