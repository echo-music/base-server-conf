# ============================================
# 基础服务环境变量配置
# ============================================

# ------------------- MySQL -------------------
MYSQL_ROOT_PASSWORD=123456

# ------------------- RabbitMQ -------------------
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=123456

# ------------------- MinIO -------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin2024!

# ------------------- Nginx API 代理 -------------------
# 后端 API 服务地址
# 方式1：如果后端在宿主机运行，使用 host.docker.internal
API_HOST=host.docker.internal:8001

# 方式2：如果后端在另一个容器，使用容器名
# API_HOST=backend:8080

# 方式3：直接指定 IP
# API_HOST=192.168.1.100:8080
